rules_version = '2';

// Locks all data to its owner. Every collection in this app lives under
// users/{userId}/... — a signed-in user can only touch their own subtree.
//
// Deploy:  firebase deploy --only firestore:rules
// (or paste into Firebase Console → Firestore → Rules)
//
// IMPORTANT: API routes must NOT read/write Firestore with the client SDK —
// server-side client-SDK calls have no auth context and these rules will
// (correctly) reject them. All Firestore I/O happens in the browser, where
// the user is authenticated; API routes receive context in the request body
// and verify identity via Firebase ID tokens (src/lib/serverAuth.ts).

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own profile document and everything beneath it
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is denied by default (no match = no access),
    // stated explicitly for clarity:
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
